HOSPEDAGENS_CAMINHOS_SUPABASE_ANON_KEY=sua_anon_key_nova

# Secrets para Edge Functions do Hospedagens.
# Preencher somente em staging/sandbox ou producao aprovada.
# Nao versionar valores reais.
